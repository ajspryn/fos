@section('content')
    @php
        $diterima = Modules\Akad\Entities\Pembiayaan::select()
            ->where('segmen', 'P3K')
            ->where('status', 'Selesai Akad')
            ->get()
            ->count();

        $ultra_mikros = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()->get();
        $proposalUltraMikro = 0;
        foreach ($ultra_mikros as $ppr) {
            $history = Modules\UltraMikro\Entities\UltraMikroPembiayaanHistory::select()
                ->where('ultra_mikro_pembiayaan_id', $ppr->id)
                ->latest()
                ->get()
                ->first();

            $proposal_ultra_mikro = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
                ->where('id', $history->ultra_mikro_pembiayaan_id)
                ->get()
                ->first();

            if (
                ($history->status_id == 11 && $history->jabatan_id == 3) ||
                ($history->status_id == 4 && $history->jabatan_id == 2)
            ) {
                $proposalUltraMikro++;
            }
        }

        $ditolak = Modules\UltraMikro\Entities\UltraMikroPembiayaanHistory::select()
            ->where('status_id', 6)
            ->get()
            ->count();

        $komites = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
            ->where('user_id', Auth::user()->id)
            ->whereNotNull('dokumen_ideb')
            ->latest()
            ->get();

        $review = 0;
        foreach ($komites as $komite) {
            $history = Modules\UltraMikro\Entities\UltraMikroPembiayaanHistory::select()
                ->where('ultra_mikro_pembiayaan_id', $komite->id)
                ->latest()
                ->get()
                ->first();

            $proposal_ultra_mikro = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
                ->where('id', $history->ultra_mikro_pembiayaan_id)
                ->get()
                ->first();

            if ($history->status_id == 7) {
                $review++;
            }
        }

        $ultra_mikroPipelines = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()->get();

        $pipeline = 0;
        foreach ($ultra_mikroPipelines as $ultra_mikroPipeline) {
            $history = Modules\UltraMikro\Entities\UltraMikroPembiayaanHistory::select()
                ->where('ultra_mikro_pembiayaan_id', $ultra_mikroPipeline->id)
                ->latest()
                ->get()
                ->first();

            $proposal_ultra_mikro = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
                ->where('id', $history->ultra_mikro_pembiayaan_id)
                ->get()
                ->first();
            if ($history->status_id != 5 || $history->jabatan_id != 2) {
                if ($history->status_id < 9) {
                    $pipeline++;
                }
            }
        }

        $batalAkad = Modules\Akad\Entities\Pembiayaan::select()
            ->where('segmen', 'P3K')
            ->where('status', 'Akad Batal')
            ->get()
            ->count();

        //Total Disburse & Margin
        $jmlDisburse = 0;
        $jmlMargin = 0;
        foreach ($proposalSelesais as $proposalSelesai) {
            $plafond = $proposalSelesai->nominal_pembiayaan;
            $jmlDisburse = $jmlDisburse + $plafond;

            $margin = $proposalSelesai->harga_margin;
            $jmlMargin = $jmlMargin + $margin;
        }
    @endphp
