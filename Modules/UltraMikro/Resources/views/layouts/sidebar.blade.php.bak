@php

    $proposalUltraMikro = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
        ->where('user_id', Auth::user()->id)
        ->whereNull('dokumen_ideb')
        ->get()
        ->count();

    $proposals = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
        ->where('user_id', Auth::user()->id)
        ->get();

    $notifRevisi = 0;
    foreach ($proposals as $proposal) {
        $history = Modules\UltraMikro\Entities\UltraMikroPembiayaanHistory::select()
            ->where('ultra_mikro_pembiayaan_id', $proposal->id)
            ->latest()
            ->get()
            ->first();

        $proposal_p3k = Modules\UltraMikro\Entities\UltraMikroPembiayaan::select()
            ->where('id', $history->ultra_mikro_pembiayaan_id)
            ->get()
            ->first();

        if ($history->status_id == 7) {
            $notifRevisi++;
        }
    }
@endphp
