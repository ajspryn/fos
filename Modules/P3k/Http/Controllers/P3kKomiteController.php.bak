     */
    public function index()
    {
        return view('p3k::komite.index', [
            'title' => 'Proposal Calon Nasabah',
            'proposals' => P3kPembiayaan::select()->where('user_id', Auth::user()->id)->whereNotNull('dokumen_ideb')->orderBy('id', 'desc')->get(),
        ]);
    }

